{
  // verify ジョブ（task verify → scripts/checks/markdown.sh）の Markdown Lint 用設定。
  // 日本語の統治文書／テンプレート様式（長文・HTMLコメント・強調見出し・先頭フロントマター/コメント・
  // 参考文献の素URL）に合わせ、誤検知となるルールのみ緩和する。本質的な構造規約は維持する。
  "default": true,
  "MD013": false,  // 行長制限（日本語の長文に不適）
  "MD024": { "siblings_only": true }, // 同一見出しは兄弟階層内のみ禁止（選択肢ごとの小見出し等を許容）
  "MD033": false,  // インラインHTML（<!-- 記入ガイド/Sync Impact Report -->）を許容
  "MD034": false,  // 素URL（参考文献の規格URL）を許容
  "MD036": false,  // 強調を見出し代わりに使用（**メリット** 等）を許容
  "MD041": false,  // 先頭行が見出しでない（YAMLフロントマター/HTMLコメント始まり）を許容
  "MD004": false,  // 箇条書き記号の混在（メタデータは * ／ 本文は - の規約）を許容
  "MD025": { "front_matter_title": "" }, // フロントマター title と本文 H1 の共存を許容（SDD 文書では既定構成）
  "MD028": false,  // 注記の引用ブロック内の空行（複数段落の note）を許容
  "MD060": false   // 表パイプの整列（コンパクト表記を採用。新しめのルールで CI 版に非搭載の場合あり）
}
